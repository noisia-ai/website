# Secrets — keep ALL env variants out of git (broad match first, then explicit).
# Only .env.example is allowed (it is force-unignored below).
.env
.env.*
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Catch ad-hoc backups/dumps of env files (e.g. .env.production-local-backup-YYYYMMDD)
*env*backup*
*.env.bak
!.env.example
!**/.env.example
tsconfig.tsbuildinfo
*.swp
