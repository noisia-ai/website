# DATABASE (Supabase)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
DATABASE_URL=postgresql://postgres:xxx@db.xxxx.supabase.co:5432/postgres

# AUTH (Kinde)
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_ISSUER_URL=https://noisiastudio.kinde.com
KINDE_SITE_URL=http://localhost:3001
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3001
# Debe apuntar a /auth/continue: esa página decide el destino por rol
# (internos -> /studio, clientes -> /signal). No la pongas en /studio.
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3001/auth/continue

# LLM (Anthropic + optional OpenAI fallback)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_FALLBACK=
OPENAI_API_KEY=

# QUEUE (Redis)
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# STORAGE (Supabase Storage)
SUPABASE_STORAGE_BUCKET_OUTPUTS=outputs
SUPABASE_STORAGE_BUCKET_CORPUS_FILES=corpus-files
SUPABASE_STORAGE_BUCKET_AVATARS=avatars

# EMAIL (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Noisia Studio <team@hey.noisia.ai>

# MONITORING
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=

# APP CONFIG
NEXT_PUBLIC_APP_NAME=Noisia Studio
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NOISIA_INTERNAL_EMAIL_DOMAINS=noisia.ai
NOISIA_BOOTSTRAP_FOUNDER_EMAILS=
# Optional: map Kinde organization code to Noisia organization slug.
# Format: org_abc:seguros-el-potosi-demo,org_xyz:another-client
NOISIA_KINDE_ORG_MAP=
NODE_ENV=development

# FEATURE FLAGS
FEATURE_WHATSAPP=false
FEATURE_MULTI_COUNTRY=false
FEATURE_BILLING=false
# Engine methodology beta runtime. Keep false in prod until migrations, seeds,
# tests and smoke QA pass. LLM coding requires the second flag too.
NOISIA_ENGINE_RUNTIME_ENABLED=false
NOISIA_ENGINE_LLM_ENABLED=false
NOISIA_ENGINE_ALLOW_OPUS=false
NOISIA_ENGINE_FIXTURE_CODING_ENABLED=false
ENGINE_ALLOW_DETERMINISTIC_SYNTHESIS=false
# Signal corpus chat synthesis. Keep false until report QA confirms retrieval,
# permissions and client-safe evidence.
NOISIA_SIGNAL_CHAT_LLM_ENABLED=false
NOISIA_SIGNAL_CHAT_ALLOW_OPUS=false
# DB seed writes. Keep false unless the target is an isolated staging/throwaway DB.
NOISIA_DB_SEED_ALLOW_REMOTE=false

# PIPELINE
QUERY_ENGINE_MAX_ITERATIONS=5
QUERY_ENGINE_SAMPLE_SIZE_PER_ITERATION=50
ANALYSIS_PIPELINE_TIMEOUT_SECONDS=900
